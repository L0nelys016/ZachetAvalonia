<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="using:Zachet.ViewModels"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Zachet.Views.CreateAndEditProductView"
             x:DataType="vm:CreateAndEditProductViewModel">

    <Grid HorizontalAlignment="Center" 
          VerticalAlignment="Center" 
          RowSpacing="10">

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" 
                   Grid.Row="0" 
                   Text="Артикул: " 
                   Margin="0 5 0 0"/>
        <TextBox Grid.Column="1" 
                 Grid.Row="0" 
                 Width="150" 
                 Text="{Binding SelectedProduct.Article}" 
                 HorizontalAlignment="Left"/>
        <TextBlock Grid.Column="0" 
                   Grid.Row="1" 
                   Text="Цена: " 
                   Margin="0 5 0 0"/>
        <TextBox Grid.Column="1" 
                 Grid.Row="1" 
                 Width="150" 
                 Text="{Binding SelectedProduct.Price}" 
                 HorizontalAlignment="Left"/>
        <TextBlock Grid.Column="0" 
                   Grid.Row="2" 
                   Text="Название: " 
                   Margin="0 5 0 0"/>
        <TextBox Grid.Column="1" 
                 Grid.Row="2"
                 Width="150" 
                 Text="{Binding SelectedProduct.ProductName}"
                 HorizontalAlignment="Left"/>

        <TextBlock Grid.Column="0" 
                   Grid.Row="3" 
                   Text="Тип изделия: " 
                   Margin="0 5 0 0"/>
        <ComboBox Grid.Column="1"
                  Grid.Row="3"
                  ItemsSource="{Binding ProductTypes}"
                  SelectedItem="{Binding SelectedProductType}"
                  Width="150">
			<ComboBox.ItemTemplate>
				<DataTemplate>
					<TextBlock Text="{Binding TypeName}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Grid.Column="0" Grid.Row="4" Text="Материал: " Margin="0 5 0 0"/>
        <ComboBox Grid.Column="1"
                  Grid.Row="4"
                  ItemsSource="{Binding Materials}"
                  SelectedItem="{Binding SelectedMaterial}"
                  Width="150">
			<ComboBox.ItemTemplate>
				<DataTemplate>
					<TextBlock Text="{Binding MaterialName}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

         <TextBlock Grid.Column="0" 
                    Grid.Row="5" 
                    Text="Дата изготовления: "
                    Margin="0 5 0 0"/>
         <DatePicker Grid.Column="1" 
                     Grid.Row="5" 
                     SelectedDate="{Binding SelectedDate}"/>   

       <StackPanel Grid.Column="1" 
                   Grid.Row="6" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Left"
                   Spacing="10"
                   Margin="0 10 0 0">
            <Button Content="Сохранить" 
                   Width="100"
                   Command="{Binding SaveProductCommand}"/>
            <Button Content="Отмена" 
                   Width="100"
                   Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>

</UserControl>
